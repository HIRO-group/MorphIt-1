    <origin rpy="-1.570796325 0 0" xyz="0 0.0823 0" />
    <parent link="wrist_3_link" />
    <child link="tool0" />
  </joint>
  <link name="world" />
  <joint name="world_joint" type="fixed">
    <parent link="world" />
    <child link="base_link" />
