<?xml version='1.0' encoding='utf-8'?>
<robot name="m1n4s200">
  <!-- links      		mesh_no
   base           		0
   shoulder       		1
   arm            		2
   forearm        		3
   wrist          		4
   arm_mico       		5
   arm_half1 (7dof)		6
   arm_half2 (7dof)		7
   wrist_spherical_1  8
   wrist_spherical_2  9

   hand 3 finger  		55
   hand_2finger   		56
   finger_proximal		57
   finger_distal      58
-->
  <!-- links      		mesh_no
   base           		0
   shoulder       		1
   arm            		2
   forearm        		3
   wrist          		4
   arm_mico       		5
   arm_half1 (7dof)		6
   arm_half2 (7dof)		7
   wrist_spherical_1  8
   wrist_spherical_2  9

   hand 3 finger  		55
   hand_2finger   		56
   finger_proximal		57
   finger_distal      58
-->
  <link name="root" />
  <!-- for gazebo -->
  <link name="world" />
  <joint name="connect_root_and_world" type="fixed">
    <child link="root" />
    <parent link="world" />
    <origin rpy="0 0 0" xyz="0 0 0" />
  </joint>
  <!-- ros_control plugin -->
  <gazebo>
    <plugin filename="libgazebo_ros_control.so" name="gazebo_ros_control">
      <robotNamespace>m1n4s200</robotNamespace>
      <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
      <legacyModeNS>true</legacyModeNS>
    </plugin>
  </gazebo>
  <link name="m1n4s200_link_base">
    <visual>
      <geometry>
        <mesh filename="package://kinova_description/meshes/base.stl" />
      </geometry>
      <material name="carbon_fiber">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <inertial>
      <mass value="0.46784" />
      <origin rpy="0 0 0" xyz="0 0 0.1255" />
      <inertia ixx="0.000951270861568" ixy="0" ixz="0" iyy="0.000951270861568" iyz="0" izz="0.00037427200000000004" />
    </inertial>
  </link>
  <joint name="m1n4s200_joint_base" type="fixed">
    <parent link="root" />
    <child link="m1n4s200_link_base" />
    <axis xyz="0 0 0" />
    <origin rpy="0 0 0" xyz="0 0 0" />
    <dynamics damping="0.0" friction="0.0" />
  </joint>
  <link name="m1n4s200_link_1">
    <visual>
      <geometry>
        <mesh filename="package://kinova_description/meshes/shoulder.stl" />
      </geometry>
      <material name="carbon_fiber">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <visual>
      <geometry>
        <mesh filename="package://kinova_description/meshes/ring_big.stl" />
      </geometry>
    </visual>
    <inertial>
      <mass value="0.7477" />
      <origin xyz="0 -0.002 -0.0605" />
      <inertia ixx="0.0015203172520400004" ixy="0" ixz="0" iyy="0.0015203172520400004" iyz="0" izz="0.00059816" />
    </inertial>
  </link>
  <joint name="m1n4s200_joint_1" type="continuous">
    <parent link="m1n4s200_link_base" />
    <child link="m1n4s200_link_1" />
    <axis xyz="0 0 1" />
    <limit effort="40" velocity="0.6283185307179586" />
    <origin rpy="0 3.141592653589793 0" xyz="0 0 0.15675" />
    <dynamics damping="0.0" friction="0.0" />
  </joint>
  <transmission name="m1n4s200_joint_1_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="m1n4s200_joint_1">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="m1n4s200_joint_1_actuator">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>160</mechanicalReduction>
    </actuator>
  </transmission>
  <!--For torque sensing in simulation-->
  <gazebo reference="m1n4s200_joint_1">
    <provideFeedback>true</provideFeedback>
  </gazebo>
  <gazebo>
    <plugin filename="libgazebo_ros_ft_sensor.so" name="ft_sensor">
      <updateRate>30.0</updateRate>
      <topicName>m1n4s200_joint_1_ft_sensor_topic</topicName>
      <jointName>m1n4s200_joint_1</jointName>
    </plugin>
  </gazebo>
  <link name="m1n4s200_link_2">
    <visual>
      <geometry>
        <mesh filename="package://kinova_description/meshes/arm_mico.stl" />
      </geometry>
      <material name="carbon_fiber">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <visual>
      <geometry>
        <mesh filename="package://kinova_description/meshes/ring_big.stl" />
      </geometry>
    </visual>
    <inertial>
      <mass value="0.85968" />
      <origin xyz="0 -0.145  -0.0076" />
      <inertia ixx="0.004670909316288" ixy="0" ixz="0" iyy="0.00038685599999999993" iyz="0" izz="0.004670909316288" />
    </inertial>
  </link>
  <joint name="m1n4s200_joint_2" type="revolute">
    <parent link="m1n4s200_link_1" />
    <child link="m1n4s200_link_2" />
    <axis xyz="0 0 1" />
    <limit effort="80" lower="0.8726646259971648" upper="5.410520681182422" velocity="0.6283185307179586" />
    <origin rpy="-1.5707963267948966 0 3.141592653589793" xyz="0 0.0016 -0.11875" />
    <dynamics damping="0.0" friction="0.0" />
  </joint>
  <transmission name="m1n4s200_joint_2_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="m1n4s200_joint_2">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="m1n4s200_joint_2_actuator">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>160</mechanicalReduction>
    </actuator>
  </transmission>
  <!--For torque sensing in simulation-->
  <gazebo reference="m1n4s200_joint_2">
    <provideFeedback>true</provideFeedback>
  </gazebo>
  <gazebo>
    <plugin filename="libgazebo_ros_ft_sensor.so" name="ft_sensor">
      <updateRate>30.0</updateRate>
      <topicName>m1n4s200_joint_2_ft_sensor_topic</topicName>
      <jointName>m1n4s200_joint_2</jointName>
    </plugin>
  </gazebo>
  <link name="m1n4s200_link_3">
    <visual>
      <geometry>
        <mesh filename="package://kinova_description/meshes/forearm_mico.stl" />
      </geometry>
      <material name="carbon_fiber">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
