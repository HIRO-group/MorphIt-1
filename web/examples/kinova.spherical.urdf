    </actuator>
  </transmission>
  <!--For torque sensing in simulation-->
  <gazebo reference="m1n4s200_joint_3">
    <provideFeedback>true</provideFeedback>
  </gazebo>
  <gazebo>
    <plugin filename="libgazebo_ros_ft_sensor.so" name="ft_sensor">
      <updateRate>30.0</updateRate>
      <topicName>m1n4s200_joint_3_ft_sensor_topic</topicName>
      <jointName>m1n4s200_joint_3</jointName>
    </plugin>
  </gazebo>
