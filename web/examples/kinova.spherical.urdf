    <inertial>
      <mass value="0.78" />
      <origin xyz="0 0 -0.06" />
      <inertia ixx="0.00037049851799999997" ixy="0" ixz="0" iyy="0.00037049851799999997" iyz="0" izz="0.0006240000000000001" />
